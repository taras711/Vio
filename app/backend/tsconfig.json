{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "./types",
      "../node_modules/@types"
    ],
  },
  "ts-node": {
    "esm": false
  },
  "include": [
    "./**/*.ts",
    "./**/*.d.ts"
, "core/license/testLicense.js"  ]

}